{
  "manifest_version": 3,
  "name": "Kiri Auto Click",
  "version": "1.0.0",
  "description": "Clicks matching download buttons and closes the tab after IDM starts the matching download.",
  "permissions": [
    "tabs",
    "nativeMessaging"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "sites.json"
      ],
      "matches": [
        "*://*/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "*://thenkiri.com/*",
        "*://*.thenkiri.com/*",
        "*://downloadwella.com/*",
        "*://*.downloadwella.com/*",
        "*://wetafiles.com/*",
        "*://*.wetafiles.com/*",
        "*://sub-scene.com/*",
        "*://*.sub-scene.com/*",
        "*://subsource.net/*",
        "*://*.subsource.net/*",
        "*://yts-subs.com/*",
        "*://*.yts-subs.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "*://thenkiri.com/*",
    "*://*.thenkiri.com/*",
    "*://downloadwella.com/*",
    "*://*.downloadwella.com/*",
    "*://wetafiles.com/*",
    "*://*.wetafiles.com/*",
    "*://sub-scene.com/*",
    "*://*.sub-scene.com/*",
    "*://subsource.net/*",
    "*://*.subsource.net/*",
    "*://yts-subs.com/*",
    "*://*.yts-subs.com/*"
  ]
}
